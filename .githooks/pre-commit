#!/usr/bin/env bash
set -euo pipefail

STAGED_GO=$(git diff --cached --name-only | grep '\.go$' || true)
STAGED_MD=$(git diff --cached --name-only | grep '\.md$' || true)

echo "▶ go test"
go test -race ./...

if [ -n "$STAGED_GO" ]; then
  echo "▶ golangci-lint"
  golangci-lint run
fi

if [ -n "$STAGED_MD" ]; then
  if command -v npx &>/dev/null; then
    echo "▶ markdownlint"
    echo "$STAGED_MD" | xargs npx --yes markdownlint-cli2
  else
    echo "⚠ npx not found — skipping markdown lint"
  fi
fi
